# Vercel deploy trigger test — remove me
# Database — MongoDB connection string
# Local: mongodb://localhost:27017/aureas_db
# Atlas: mongodb+srv://[user]:[password]@[cluster].mongodb.net/aureas_db
DATABASE_URI=mongodb://localhost:27017/aureas_db

# Payload secret — minimum 32 characters, used for JWT signing
PAYLOAD_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_MIN_32_CHARS

# Server URL — where Payload admin + API runs
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Frontend URL — CORS whitelist for the Next.js web app
FRONTEND_URL=http://localhost:3000

# Cloudflare R2 Storage
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev
