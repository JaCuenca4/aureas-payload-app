# Database — MongoDB connection string
# Local: mongodb://localhost:27017/palea_db
# Atlas: mongodb+srv://[user]:[password]@[cluster].mongodb.net/palea_db
DATABASE_URI=mongodb://localhost:27017/palea_db

# Payload secret — minimum 32 characters, used for JWT signing
PAYLOAD_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_MIN_32_CHARS

# Server URL — where Payload admin + API runs
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Frontend URL — CORS whitelist for the Next.js web app
FRONTEND_URL=http://localhost:3000
