{
  "name": "paleaec-payload-app",
  "version": "1.0.0",
  "description": "Palea EC — Payload CMS backend for e-commerce and content management",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.79.0",
    "@payloadcms/next": "^3.79.0",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "graphql": "^16.8.1",
    "next": "~15.4.11",
    "payload": "^3.79.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.9",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "~15.4.11",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
